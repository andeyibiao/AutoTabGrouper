{
  "manifest_version": 3,
  "name": "Auto Tab Grouper",
  "version": "1.0",
  "description": "自动检测标签页域名，发现多个相同域名的标签页时将其自动原生归组，并分配颜色与命名。",
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon_16.png",
      "48": "icon_48.png",
      "128": "icon_128.png"
    }
  },
  "permissions": [
    "tabs",
    "tabGroups"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
